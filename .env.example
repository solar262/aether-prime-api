# AETHER_PRIME - OAuth Credentials Template
# Copy this file to .env and fill in your values.
# You get these by creating a "Connected App" in each platform.

# === SALESFORCE ===
# 1. Go to Setup > App Manager > New Connected App
# 2. Enable OAuth, set callback to: http://localhost:3005/auth/salesforce/callback
# 3. Add scopes: api, refresh_token
SALESFORCE_CLIENT_ID=your_salesforce_consumer_key
SALESFORCE_CLIENT_SECRET=your_salesforce_consumer_secret
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com

# === HUBSPOT ===
# 1. Go to HubSpot > Settings > Integrations > Private Apps
# 2. Create app, set callback to: http://localhost:3005/auth/hubspot/callback
# 3. Add scopes: crm.objects.deals.read, crm.objects.contacts.read
HUBSPOT_CLIENT_ID=your_hubspot_app_client_id
HUBSPOT_CLIENT_SECRET=your_hubspot_app_client_secret

# === SERVER ===
PORT=3005
SESSION_SECRET=aether_prime_secure_session_key
